# Copy to .env for local development. All values below are safe demo defaults.

# Port for the traditional (non-serverless) server
PORT=3000

# Session cookie signing secret — set a long random value in real deployments
SESSION_SECRET=change-this-to-a-long-random-string

# Where the SQLite database file lives.
# On Vercel, only /tmp is writable, so this is set automatically in api/app.js.
DB_PATH=./data/usf-capital.db

# Simulation speed multiplier — how much faster than real time the market ticks.
# 1 = real time. Demo default is fast so the charts visibly move.
SIM_SPEED=8640

# How often (ms) the server appends a new tick to active positions.
TICK_INTERVAL_MS=4000

NODE_ENV=development
