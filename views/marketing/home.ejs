<%- include('../partials/head', { title: 'Apex Macro Lab' }) %>
<%- include('../partials/nav') %>
<%- include('../partials/disclaimer') %>
<main id="main">
  <%- include('../partials/flash') %>

  <% const heroProjected = Math.round(totalCapDollars * (1 + heroStat.avgReturnPct)); %>

  <section class="hero hero-apex container">
    <div class="hero-copy">
      <p class="eyebrow">Simulated forex and multi-asset capital lab</p>
      <h1>Build a premium portfolio desk without touching real money.</h1>
      <p class="lead">
        USF Capital turns a fictional deposit into a live training cockpit: FX-style market pulse,
        four simulated allocation pools, portfolio math, demo identity flow, security controls and a dashboard that moves as the engine ticks.
      </p>

      <div class="hero-actions">
        <a href="/register" class="btn btn-primary btn-large">Launch Demo Portfolio</a>
        <a href="/pools" class="btn btn-secondary btn-large">Compare Pools</a>
      </div>

      <div class="hero-metrics hero-metrics-apex" aria-label="Platform highlights">
        <div>
          <span class="metric-value">$<%= totalCapDollars.toLocaleString('en-US', { maximumFractionDigits: 0 }) %></span>
          <span class="metric-label">fictional funding ceiling</span>
        </div>
        <div>
          <span class="metric-value <%= heroStat.avgReturnPct >= 0 ? 'positive' : 'negative' %>">
            <%= heroStat.avgReturnPct >= 0 ? '+' : '' %><%= (heroStat.avgReturnPct * 100).toFixed(1) %>%
          </span>
          <span class="metric-label">avg. simulated pool drift, <%= heroStat.days %> days</span>
        </div>
        <div>
          <span class="metric-value"><%= lockYears %>Y</span>
          <span class="metric-label">illustrative lock cycle</span>
        </div>
      </div>

      <p class="fine-print hero-note">All figures are generated by software. No real deposits, trades, custody, advice or investment products exist here.</p>
    </div>

    <aside class="hero-market-card card" aria-label="Simulated portfolio command card">
      <div class="market-card-topline">
        <span>USF Apex Desk</span>
        <strong>Simulation live</strong>
      </div>
      <div class="market-card-value">
        <span>Demo portfolio path</span>
        <strong>$<%= totalCapDollars.toLocaleString('en-US', { maximumFractionDigits: 0 }) %> to $<%= heroProjected.toLocaleString('en-US', { maximumFractionDigits: 0 }) %></strong>
      </div>
      <canvas id="hero-pools-chart" data-chart-type="multiline" height="210" role="img"
        aria-label="Simulated hero performance chart for USF Capital pools" tabindex="0"></canvas>
      <script type="application/json" id="hero-pools-chart-data"><%- JSON.stringify({
        formatValue: 'index',
        series: seriesByPool.map(({ pool, series }) => ({
          label: pool.name,
          color: pool.color,
          points: series.slice(-90).map(p => ({ ts: p.ts, value: p.index_value }))
        }))
      }) %></script>
      <div class="market-card-grid">
        <span>Risk gate</span><strong>Armed</strong>
        <span>Ledger</span><strong>Demo only</strong>
        <span>Data</span><strong>Synthetic</strong>
      </div>
    </aside>
  </section>

  <section class="ticker-tape" aria-label="Live simulated market tape">
    <div class="ticker-tape-track container">
      <span class="ticker-label">Market pulse</span>
      <ul id="ticker-list" class="ticker-list ticker-tape-list">
        <li class="ticker-placeholder">Loading simulated prices...</li>
      </ul>
    </div>
  </section>

  <section class="container section-block">
    <div class="section-heading section-heading-row">
      <div>
        <p class="eyebrow">Allocation desk</p>
        <h2>Four pools with different behavior, volatility and story.</h2>
        <p>Each card is powered by the same synthetic series engine used across the public pages and investor dashboard.</p>
      </div>
      <a href="/pools" class="btn btn-ghost btn-small">Full Pool Library</a>
    </div>

    <div class="pool-snapshot-grid">
      <% seriesByPool.forEach(({ pool, series }, index) => {
        const first = series[0].index_value;
        const last = series[series.length - 1].index_value;
        const returnPct = (last / first - 1) * 100;
      %>
        <article class="pool-snapshot card">
          <div class="pool-snapshot-head">
            <span class="pool-token" style="border-color:<%= pool.color %>; color:<%= pool.color %>">0<%= index + 1 %></span>
            <span class="risk-badge" style="background:<%= pool.color %>"><%= pool.risk_profile %></span>
          </div>
          <h3><a href="/pools/<%= pool.key %>"><%= pool.name %></a></h3>
          <p><%= pool.tagline %></p>
          <canvas id="home-spark-<%= pool.key %>" data-chart-type="sparkline" height="96" role="img"
            aria-label="<%= pool.name %> simulated 180 day sparkline" tabindex="0"></canvas>
          <script type="application/json" id="home-spark-<%= pool.key %>-data"><%- JSON.stringify({
            formatValue: 'index',
            color: pool.color,
            points: series.map(p => ({ ts: p.ts, value: p.index_value }))
          }) %></script>
          <dl class="pool-facts compact-facts">
            <div><dt>Sim drift</dt><dd class="<%= returnPct >= 0 ? 'positive' : 'negative' %>"><%= returnPct >= 0 ? '+' : '' %><%= returnPct.toFixed(1) %>%</dd></div>
            <div><dt>Target range</dt><dd><%= (pool.target_low * 100).toFixed(0) %>% to <%= (pool.target_high * 100).toFixed(0) %>%</dd></div>
          </dl>
        </article>
      <% }) %>
    </div>
  </section>

  <section class="container section-block operating-system">
    <div class="section-heading">
      <p class="eyebrow">Inside the machine</p>
      <h2>A complete miniature fintech journey, not a decorative landing page.</h2>
      <p>The experience is designed to feel like a capital platform while staying completely fictional and transparent.</p>
    </div>
    <div class="strategy-grid">
      <article class="strategy-card">
        <span class="strategy-number">01</span>
        <h3>Account command center</h3>
        <p>Registration, login, session review, settings and optional authenticator-app 2FA create a real account journey.</p>
      </article>
      <article class="strategy-card">
        <span class="strategy-number">02</span>
        <h3>Virtual funding rail</h3>
        <p>Mock funding choices credit fictional cash instantly without collecting real payment details.</p>
      </article>
      <article class="strategy-card">
        <span class="strategy-number">03</span>
        <h3>Allocation engine</h3>
        <p>Users split simulated cash across four pools and watch values update through backend-generated performance ticks.</p>
      </article>
      <article class="strategy-card">
        <span class="strategy-number">04</span>
        <h3>Guarded exits</h3>
        <p>Withdrawal routes apply lock-cycle and penalty logic, then credit the fictional cash ledger.</p>
      </article>
    </div>
  </section>

  <section class="container proof-band">
    <div class="proof-card">
      <strong>Strict CSP</strong>
      <span>External scripts only, no inline JS attributes.</span>
    </div>
    <div class="proof-card">
      <strong>Request IDs</strong>
      <span>Every response gets traceable debugging context.</span>
    </div>
    <div class="proof-card">
      <strong>CSRF + rate limits</strong>
      <span>Money-like actions are guarded even in demo mode.</span>
    </div>
    <div class="proof-card">
      <strong>Demo identity flow</strong>
      <span>A guided verification path without outside services.</span>
    </div>
  </section>

  <section class="container cta-band cta-legendary">
    <p class="eyebrow">Enter the lab</p>
    <h2>Open a simulated account and run the full investor journey.</h2>
    <p>No real funds, no real payment rails, no financial products. Just the product experience, the engine, and the capital-desk interface.</p>
    <div class="hero-actions centered-actions">
      <a href="/register" class="btn btn-primary btn-large">Launch Demo Portfolio</a>
      <a href="/about" class="btn btn-secondary btn-large">About The Build</a>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
<script src="/js/ticker.js"></script>
<script src="/js/charts.js"></script>
