<%- include('../partials/head', { title: 'Simulated Global Investing' }) %>
<%- include('../partials/nav') %>
<%- include('../partials/disclaimer') %>
<main id="main">
  <%- include('../partials/flash') %>

  <section class="hero container">
    <div class="hero-copy">
      <p class="eyebrow">A live, ticking simulation</p>
      <h1>Watch a simulated global portfolio grow, in plain language.</h1>
      <p class="lead">
        USF Capital is a demo investment platform. Open a free simulated account, allocate a small virtual
        deposit across four illustrative pools, and watch real-time simulated charts move — no real money,
        ever.
      </p>
      <div class="hero-stat">
        <span class="hero-stat-value <%= heroStat.avgReturnPct >= 0 ? 'positive' : 'negative' %>">
          <%= heroStat.avgReturnPct >= 0 ? '+' : '' %><%= (heroStat.avgReturnPct * 100).toFixed(1) %>%
        </span>
        <span class="hero-stat-label">average simulated pool growth over the last <%= heroStat.days %> days</span>
      </div>
      <div class="hero-actions">
        <a href="/register" class="btn btn-primary btn-large">Open a Free Simulated Account</a>
        <a href="/how-it-works" class="btn btn-secondary btn-large">See How It Works</a>
      </div>
    </div>
    <div class="hero-ticker card" aria-label="Live simulated market ticker">
      <h2 class="card-title">Live Market Snapshot</h2>
      <ul id="ticker-list" class="ticker-list">
        <li class="ticker-placeholder">Loading live prices&hellip;</li>
      </ul>
      <p class="fine-print">Illustrative prices, simulated and updated automatically. Not real market data.</p>
    </div>
  </section>

  <section class="container trust-strip" aria-label="Illustrative trust badges">
    <div class="trust-badge">
      <strong>Bank-Grade Encryption*</strong>
      <span>Every page uses HTTPS and strict security headers.</span>
    </div>
    <div class="trust-badge">
      <strong>Simulated Audit Trail*</strong>
      <span>Every account action is logged and viewable by you.</span>
    </div>
    <div class="trust-badge">
      <strong>Illustrative KYC*</strong>
      <span>A guided identity check demonstrates a real onboarding flow.</span>
    </div>
    <p class="fine-print">*Illustrative demo features. USF Capital is not a licensed or regulated financial institution.</p>
  </section>

  <section class="container">
    <div class="section-heading">
      <h2>A snapshot of all four simulated pools</h2>
      <p>This chart is generated by the same simulation engine that powers investor dashboards.</p>
    </div>
    <div class="card">
      <canvas id="home-pools-chart" data-chart-type="multiline" height="360" role="img"
        aria-label="Simulated index performance for four investment pools over the last 180 days" tabindex="0"></canvas>
      <script type="application/json" id="home-pools-chart-data"><%- JSON.stringify({
        formatValue: 'index',
        series: seriesByPool.map(({ pool, series }) => ({
          label: pool.name,
          color: pool.color,
          points: series.map(p => ({ ts: p.ts, value: p.index_value }))
        }))
      }) %></script>
    </div>
  </section>

  <section class="container value-props">
    <div class="value-prop">
      <h3>1. Deposit a small virtual amount</h3>
      <p>Fund your simulated account instantly with a mock card, bank, or crypto selection. Nothing is charged.</p>
    </div>
    <div class="value-prop">
      <h3>2. Choose your simulated pools</h3>
      <p>Spread your deposit across four illustrative strategies, from conservative to aggressive.</p>
    </div>
    <div class="value-prop">
      <h3>3. Watch it tick, live</h3>
      <p>Your dashboard updates automatically as the simulation engine advances your positions.</p>
    </div>
  </section>

  <section class="container cta-band">
    <h2>Ready to see it for yourself?</h2>
    <p>Create a free simulated account in under a minute. No payment details are ever required.</p>
    <a href="/register" class="btn btn-primary btn-large">Open a Free Simulated Account</a>
  </section>
</main>
<%- include('../partials/footer') %>
<script src="/js/ticker.js"></script>
<script src="/js/charts.js"></script>
