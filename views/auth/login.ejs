<%- include('../partials/head', { title: 'Log In' }) %>
<%- include('../partials/nav') %>
<%- include('../partials/disclaimer') %>
<main id="main" class="container narrow">
  <div class="card form-card">
    <h1>Log In</h1>

    <% if (errors && errors.length) { %>
      <div class="form-errors" role="alert">
        <ul><% errors.forEach(e => { %><li><%= e %></li><% }) %></ul>
      </div>
    <% } %>

    <form action="/login" method="post" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="next" value="<%= next %>">

      <label for="email">Email address</label>
      <input type="email" id="email" name="email" autocomplete="email" required value="<%= values.email || '' %>">

      <label for="password">Password</label>
      <input type="password" id="password" name="password" autocomplete="current-password" required>

      <button type="submit" class="btn btn-primary btn-large btn-block">Log In</button>
    </form>

    <p class="form-footnote">New here? <a href="/register">Create a free account</a></p>
  </div>
</main>
<%- include('../partials/footer') %>
