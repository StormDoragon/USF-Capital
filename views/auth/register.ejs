<%- include('../partials/head', { title: 'Create Your Account' }) %>
<%- include('../partials/nav') %>
<%- include('../partials/disclaimer') %>
<main id="main" class="container narrow">
  <div class="card form-card">
    <h1>Create Your Free Account</h1>
    <p class="lead">It takes less than a minute. No payment details are ever required.</p>

    <% if (errors && errors.length) { %>
      <div class="form-errors" role="alert">
        <ul><% errors.forEach(e => { %><li><%= e %></li><% }) %></ul>
      </div>
    <% } %>

    <form action="/register" method="post" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <label for="fullName">Full name</label>
      <input type="text" id="fullName" name="fullName" autocomplete="name" required value="<%= values.fullName || '' %>">

      <label for="email">Email address</label>
      <input type="email" id="email" name="email" autocomplete="email" required value="<%= values.email || '' %>">

      <label for="password">Password</label>
      <input type="password" id="password" name="password" autocomplete="new-password" required minlength="10">
      <p class="field-hint">At least 10 characters, with a letter and a number.</p>

      <label for="confirmPassword">Confirm password</label>
      <input type="password" id="confirmPassword" name="confirmPassword" autocomplete="new-password" required minlength="10">

      <button type="submit" class="btn btn-primary btn-large btn-block">Create Account</button>
    </form>

    <p class="form-footnote">Already have an account? <a href="/login">Log in</a></p>
  </div>
</main>
<%- include('../partials/footer') %>
