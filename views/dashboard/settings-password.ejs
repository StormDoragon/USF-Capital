<%- include('../partials/head', { title: 'Change Password' }) %>
<%- include('../partials/nav') %>
<%- include('../partials/disclaimer') %>
<main id="main" class="container narrow">
  <p><a href="/settings">&larr; Back to Settings</a></p>
  <div class="card form-card">
    <h1>Change Password</h1>

    <% if (errors && errors.length) { %>
      <div class="form-errors" role="alert">
        <ul><% errors.forEach(e => { %><li><%= e %></li><% }) %></ul>
      </div>
    <% } %>

    <form action="/settings/password" method="post" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <label for="currentPassword">Current password</label>
      <input type="password" id="currentPassword" name="currentPassword" autocomplete="current-password" required>

      <label for="newPassword">New password</label>
      <input type="password" id="newPassword" name="newPassword" autocomplete="new-password" required minlength="10">
      <p class="field-hint">At least 10 characters, with a letter and a number.</p>

      <label for="confirmPassword">Confirm new password</label>
      <input type="password" id="confirmPassword" name="confirmPassword" autocomplete="new-password" required minlength="10">

      <button type="submit" class="btn btn-primary btn-large btn-block">Update Password</button>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
